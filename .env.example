# ── STT Server ────────────────────────────────────────────────────────────────
STT_DEVICE=cuda
STT_MODEL_SIZE=large-v3          # large-v3 = best quality / distil-large-v3 = faster
STT_COMPUTE_TYPE=float16         # float16 = GPU / int8 = CPU
STT_LANGUAGE=en                  # en | hi | multi
STT_BEAM_SIZE=5
STT_VAD_THRESHOLD=0.5
STT_SILENCE_MS=300
STT_PARTIAL_INTERVAL_MS=400
STT_API_TOKEN=                   # leave blank to disable auth

# ── TTS Server ────────────────────────────────────────────────────────────────
TTS_DEVICE=cuda
TTS_DEFAULT_VOICE=ahana
TTS_API_TOKEN=                   # leave blank to disable auth
